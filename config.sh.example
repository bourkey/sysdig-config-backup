#!/usr/bin/env bash
# Sysdig Config Backup — Configuration
#
# Copy this file to config.sh and fill in your values.
# config.sh is gitignored to prevent token leakage.
#
# Alternatively, export these variables in your environment
# or cron environment directly.

# Required: Your Sysdig Secure API token
# Generate one at: Sysdig Secure → Profile → User Settings → Sysdig API token
export SYSDIG_API_TOKEN="your-api-token-here"

# Optional: Sysdig Secure API base URL (default: US region)
# Common regions:
#   US:  https://secure.sysdig.com
#   EU:  https://eu1.app.sysdig.com
#   US2: https://us2.app.sysdig.com
#   AU:  https://app.au1.sysdig.com
export SYSDIG_API_URL="https://secure.sysdig.com"

# Optional: Disable TLS certificate verification (on-prem with self-signed certs)
# WARNING: This disables all certificate validation and exposes connections to
# man-in-the-middle attacks. Use SYSDIG_CA_CERT instead where possible.
# export SYSDIG_TLS_INSECURE="true"

# Optional: Custom CA certificate bundle (on-prem with a private CA)
# Set to the path of a PEM file containing your CA certificate(s).
# export SYSDIG_CA_CERT="/etc/ssl/certs/my-ca.pem"

# Optional: Number of resources fetched per API request (default: 100)
# Increase for faster exports on large tenants (check your API plan's max limit).
# export SYSDIG_PAGE_SIZE="100"

# Optional: Max Terraform resources per output file before splitting (default: 200)
# Set to 0 to disable splitting and always write a single file per resource type.
# export SYSDIG_TF_CHUNK_SIZE="200"

# Optional: Passphrase for encrypting credential fields in backup JSON files.
# When set, known credential fields (service_key, api_key, token, password, etc.)
# are encrypted with AES-256-CBC before being committed to git. Encrypted values
# are stored inline as enc:v1:<base64ciphertext> and can be decrypted with restore.sh.
#
# If unset, credential fields are replaced with "REDACTED" — the backup will be
# committed safely, but it cannot be used to fully restore notification channels.
#
# WARNING: Losing this passphrase makes encrypted backup fields unrecoverable.
# Store it in a password manager or secrets vault, not alongside this file.
# export SYSDIG_BACKUP_PASSPHRASE="choose-a-strong-passphrase"
