#!/usr/bin/env bash
# Sysdig Config Backup — Configuration
#
# Copy this file to config.sh and fill in your values.
# config.sh is gitignored to prevent token leakage.
#
# Alternatively, export these variables in your environment
# or cron environment directly.

# Required: Your Sysdig Secure API token
# Generate one at: Sysdig Secure → Profile → User Settings → Sysdig API token
export SYSDIG_API_TOKEN="your-api-token-here"

# Optional: Sysdig Secure API base URL (default: US region)
# Common regions:
#   US:  https://secure.sysdig.com
#   EU:  https://eu1.app.sysdig.com
#   US2: https://us2.app.sysdig.com
#   AU:  https://app.au1.sysdig.com
export SYSDIG_API_URL="https://secure.sysdig.com"

# Optional: Disable TLS certificate verification (on-prem with self-signed certs)
# WARNING: This disables all certificate validation and exposes connections to
# man-in-the-middle attacks. Use SYSDIG_CA_CERT instead where possible.
# export SYSDIG_TLS_INSECURE="true"

# Optional: Custom CA certificate bundle (on-prem with a private CA)
# Set to the path of a PEM file containing your CA certificate(s).
# export SYSDIG_CA_CERT="/etc/ssl/certs/my-ca.pem"
